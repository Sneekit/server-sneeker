# ---- Discord ----
# Bot token from https://discord.com/developers/applications  (Bot > Reset Token)
DISCORD_TOKEN=your-bot-token-here
# Application (client) ID from the same page > General Information
CLIENT_ID=your-application-id-here
# Your Discord server (guild) ID  (enable Developer Mode, right-click server > Copy Server ID)
GUILD_ID=your-guild-id-here
# The ONLY channel where /start and /stop will work (right-click channel > Copy Channel ID)
ALLOWED_CHANNEL_ID=your-channel-id-here

# ---- RCON (used for graceful shutdown) ----
# This must match ServerAdminPassword. The bot also passes it to the server on launch.
RCON_PASSWORD=change-me-to-a-strong-password
